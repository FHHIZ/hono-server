// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  // binaryTargets = ["native", "rhel-openssl-3.0.x"]
  // binaryTargets = ["native", "windows"] // windows only
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  id                     String   @id @default(cuid())
  name                   String   @unique @db.VarChar(64)
  slug                   String   @unique @db.VarChar(10)
  email                  String   @unique
  password               String   @db.VarChar(128)
  role                   Role     @default(UNREGISTERED)
  student                Student?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  last_password_updateAt DateTime @default(now())
}

model Student {
  id       String    @id @default(cuid())
  user_id  String    @unique
  class_id String
  nis      String    @unique @db.VarChar(20)
  absences Absence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  Users @relation(fields: [user_id], references: [id])
  class Class @relation(fields: [class_id], references: [id])
}

model Absence {
  id           String           @id @default(cuid())
  student_id   String
  absence_time DateTime         @db.Time
  absence_date DateTime         @db.Date
  resubmitAt   DateTime?        @db.Time
  has_todo     Boolean          @default(false)
  status       AttendanceStatus @default(ABSENT)
  teacher_note String?          @db.VarChar(255)
  todo_list    TodoList[]

  student Student @relation(fields: [student_id], references: [id])

  @@unique([student_id, absence_date])
}

model TodoList {
  id          String   @id @default(cuid())
  absence_id  String
  activity    String   @db.VarChar(255)
  description String?
  done        Boolean? @default(false)
  deadline    DateTime?
  createdAt   DateTime @default(now())

  absences Absence @relation(fields: [absence_id], references: [id], onDelete: Cascade)
}

model Class {
  id           String     @id @default(cuid())
  classes      ClassGrade
  major        String     @db.VarChar(100)
  academicYear String     @db.VarChar(9)
  student      Student[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  UNREGISTERED
}

enum AttendanceStatus {
  PRESENT
  LATE
  LEAVE
  SICK
  ABSENT
  RESUBMIT
}

enum ClassGrade {
  X
  XI
  XII
}
